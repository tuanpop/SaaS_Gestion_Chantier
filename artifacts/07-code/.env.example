# ============================================================
# ClawBTP — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# JAMAIS commiter .env.local — il est dans .gitignore.
# ============================================================

# ============================================================
# PUBLIQUES (exposées côté client — préfixe NEXT_PUBLIC_ obligatoire)
# ============================================================

# URL de votre projet Supabase (ex: https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé anonyme Supabase (safe côté client — RLS protège les données)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL de l'application (ex: https://app.clawbtp.fr en prod, http://localhost:3000 en dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clé publique VAPID pour Web Push — Sprint 3+ (laisser vide en Sprint 1)
NEXT_PUBLIC_VAPID_KEY=

# ============================================================
# SERVEUR UNIQUEMENT (JAMAIS en NEXT_PUBLIC_ — ne jamais préfixer avec NEXT_PUBLIC_)
# ============================================================

# Clé service role Supabase — bypass RLS total.
# DANGER: ne jamais exposer côté client ni commiter.
# Utilisée uniquement dans lib/supabase/admin.ts (création org, auth-hook).
SUPABASE_SERVICE_ROLE_KEY=

# URL Redis (ex: redis://localhost:6379 en dev, redis://redis:6379 en Docker)
REDIS_URL=redis://localhost:6379

# Clé API Resend pour les emails transactionnels (bienvenue, invitations)
RESEND_API_KEY=

# Clé de chiffrement AES-256-GCM pour les QR tokens des ouvriers.
# OBLIGATOIRE : 32 bytes en hexadécimal (64 caractères hex).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DANGER: si cette clé change, tous les QR codes existants deviennent invalides.
# JAMAIS en NEXT_PUBLIC_ — serveur uniquement (lib/crypto.ts).
QR_ENCRYPTION_KEY=

# Secret partagé pour authentifier les endpoints cron (header x-cron-secret).
# Sprint 1 : non utilisé mais variable préparée pour Sprint 5+.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Clé API Anthropic — Sprint 5+ (laisser vide en Sprint 1)
ANTHROPIC_API_KEY=

# Clé privée VAPID pour Web Push — Sprint 3+ (laisser vide en Sprint 1)
VAPID_PRIVATE_KEY=

# Clé API OpenWeather pour les briefings météo — Sprint 5+ (laisser vide en Sprint 1)
OPENWEATHER_API_KEY=

# ============================================================
# AUTOMATIQUES (gérées par Next.js/l'environnement)
# ============================================================

# Environnement d'exécution — 'development' | 'production' | 'test'
# NODE_ENV=development  (géré automatiquement par Next.js)
