# .env.test.example — Template pour les tests E2E contre la branche Supabase test
# Copier ce fichier en .env.test et remplir les valeurs (JAMAIS commiter .env.test)
# Provisionnée par Tanjiro étape 2 (D-2.5-026, F003 levée)
#
# En CI : ces variables sont injectées comme GitHub Secrets (Tanjiro étape 11)
# En local : copier ce fichier en .env.test et remplir

# URL de la branche Supabase test (pas la prod !)
SUPABASE_TEST_URL=https://XXXXX.supabase.co

# Clé SERVICE_ROLE de la branche test (bypass RLS — jamais en NEXT_PUBLIC_)
SUPABASE_TEST_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Ref du projet Supabase PROD (guard anti-prod dans seed.ts)
SUPABASE_PROD_PROJECT_REF=XXXXX

# URL de l'app Next.js à tester (preview Dokploy ou localhost)
BASE_URL=http://localhost:3000

# Variables Supabase PROD (copiées depuis .env.local) — nécessaires pour les gardes anti-prod
NEXT_PUBLIC_SUPABASE_URL=https://PROD_XXXX.supabase.co
